    "script": [
      {
        "cmd": "代入ｂ",
        "params": [
          "人物::德川家康.年齡"
        ]
      },
      {
        "cmd": "自語",
        "params": [],
        "text": "我也近乎<ｂ>了……差不多也得認真的考慮有關後繼者的問題不可了……"
      },
      {
        "cmd": "旁白",
        "params": [],
        "text": "(德川家康)的兒子們之中，能做為後繼者的在這個時期有三個人……"
      },
      {
        "cmd": "對話",
        "params": [
          "結城秀康,主人公"
        ],
        "text": "次男(結城秀康)"
      },
      {
        "cmd": "對話",
        "params": [
          "德川秀忠,主人公"
        ],
        "text": "三男(德川秀忠)"
      },
      {
        "cmd": "對話",
        "params": [
          "松平忠吉,主人公"
        ],
        "text": "還有四男(松平忠吉)……"
      },
      {
        "cmd": "旁白",
        "params": [],
        "text": "自從在前幾年，將(結城秀康.名)以養子的身份送到豐臣秀吉那裡去以來，(德川家康.名)便認定嫡男為(德川秀忠.名)……"
      },
      {
        "cmd": "旁白",
        "params": [],
        "text": "但是，另外兩位兒子也是相當優秀，(德川家康.名)因此相當地猶豫……"
      },
      {
        "cmd": "旁白",
        "params": [],
        "text": "(德川家康.名)集合了曾身為城主的家臣們，向他們詢問兒子們之中，應該選誰作為繼承人……"
      },
      {
        "cmd": "對話",
        "params": [
          "德川家康,本多正信"
        ],
        "text": "今天找你們來不為別的事就是想問你們覺得我的兒子們之中誰應該成為繼承人。"
      },
      {
        "cmd": "對話",
        "params": [
          "大久保忠鄰,德川家康"
        ],
        "text": "什麼！？嫡男不是早就已經定為(德川秀忠.名)大人了嗎？"
      },
      {
        "cmd": "對話",
        "params": [
          "平岩親吉,德川家康"
        ],
        "text": "的確……若是要變更一旦決定的後繼人選，便會造成家中騷動的根源。"
      },
      {
        "cmd": "對話",
        "params": [
          "德川家康,本多正信"
        ],
        "text": "但是，(德川秀忠.名)在重要的關原合戰竟然發生遲到這種事，若要被追究到身為大將的器量也無可奈何。"
      },
      {
        "cmd": "對話",
        "params": [
          "德川家康,本多正信"
        ],
        "text": "也因此，我才要問問你們，誰最適合作為我的後繼者，不必有所忌憚盡管說出意見吧……"
      },
      {
        "cmd": "對話",
        "params": [
          "平岩親吉,德川家康"
        ],
        "text": "在下……無法回答。"
      },
      {
        "cmd": "對話",
        "params": [
          "本多忠勝,德川家康"
        ],
        "text": "在下也是。惟有跟隨主公已經選定的後繼者人選一途而已。"
      },
      {
        "cmd": "對話",
        "params": [
          "德川家康,本多正信"
        ],
        "text": "嗯、(本多正信.名)的意見如何？"
      },
      {
        "cmd": "對話",
        "params": [
          "本多正信,德川家康"
        ],
        "text": "在下惶恐，如果主公能夠原諒無所忌憚的意見，在下認為只有(結城秀康.名)大人最適合。"
      },
      {
        "cmd": "對話",
        "params": [
          "大久保忠鄰,德川家康"
        ],
        "text": "你說什麼！！"
      },
      {
        "cmd": "對話",
        "params": [
          "本多正信,德川家康"
        ],
        "text": "雖然說(結城秀康.名)大人到豐臣家去當了養子，但是很明顯地他是真正繼承了主公最多的資質。"
      },
      {
        "cmd": "對話",
        "params": [
          "本多正信,德川家康"
        ],
        "text": "想要繼承制霸於戰國之世的主公衣缽，或許只有(結城秀康.名)大人才是最適合的人選……"
      },
      {
        "cmd": "對話",
        "params": [
          "大久保忠鄰,德川家康"
        ],
        "text": "你這是什麼話！一旦繼承人已經決定是(德川秀忠.名)大人了……"
      },
      {
        "cmd": "對話",
        "params": [
          "大久保忠鄰,德川家康"
        ],
        "text": "我等只有全力支持才是真正的忠義。"
      },
      {
        "cmd": "對話",
        "params": [
          "德川家康,井伊直政"
        ],
        "text": "那麼，(大久保忠鄰.名)是認為(德川秀忠.名)才是最適合的嗎？"
      },
      {
        "cmd": "對話",
        "params": [
          "大久保忠鄰,德川家康"
        ],
        "text": "當然！像後繼者之位被奪走這般不體面之事，絕對不能發生(德川秀忠.名)大人身上！"
      },
      {
        "cmd": "對話",
        "params": [
          "大久保忠鄰,德川家康"
        ],
        "text": "關原之戰會遲到都是我等家臣的怠慢之故！請大人千萬不要捨棄少主！"
      },
      {
        "cmd": "對話",
        "params": [
          "德川家康,本多正純"
        ],
        "text": "那麼，(本多正純.名)你覺得如何？"
      },
      {
        "cmd": "對話",
        "params": [
          "本多正純,德川家康"
        ],
        "text": "在下認為……應該要(結城秀康.名)大人或是(德川秀忠.名)大人的兩者之一，作為後繼者。"
      },
      {
        "cmd": "對話",
        "params": [
          "井伊直政,德川家康"
        ],
        "text": "你言下之意聽起來簡直就像是在說(松平忠吉.名)大人是無能之輩一般，這不會太無禮了嗎！"
      },
      {
        "cmd": "對話",
        "params": [
          "本多正純,德川家康"
        ],
        "text": "不，我並沒有那個意思……"
      },
      {
        "cmd": "對話",
        "params": [
          "井伊直政,德川家康"
        ],
        "text": "在下認為(松平忠吉.名)大人才是最適合的人選！"
      },
      {
        "cmd": "對話",
        "params": [
          "德川家康,本多正純"
        ],
        "text": "哦……"
      },
      {
        "cmd": "對話",
        "params": [
          "井伊直政,德川家康"
        ],
        "text": "在下認為在眾兄弟之中最有人望的就是(松平忠吉.名)大人！在下想要推薦(松平忠吉.名)大人！"
      },
      {
        "cmd": "對話",
        "params": [
          "德川家康,本多正純"
        ],
        "text": "嗯……意見如此紛歧嗎？"
      },
      {
        "cmd": "對話",
        "params": [
          "本多正純,德川家康"
        ],
        "text": "主公，不管是哪一位，都應該要趕快下決定。"
      },
      {
        "cmd": "對話",
        "params": [
          "平岩親吉,德川家康"
        ],
        "text": "慢吞吞的話，會成為家中騷亂的根源……"
      },
      {
        "cmd": "對話",
        "params": [
          "本多忠勝,德川家康"
        ],
        "text": "不管您決定哪一位，我等都會遵從您的決斷！"
      },
      {

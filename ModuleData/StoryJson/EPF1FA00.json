    "script": [
      {
        "cmd": "旁白",
        "params": [],
        "text": "這一年，(德川家康)改名家康。因為要把今川義元所賜的『元』字捨去而從此開始過新的人生……"
      },
      {
        "cmd": "旁白",
        "params": [],
        "text": "並且也把姓氏的松平改去，以『德川』之姓自稱。"
      },
      {
        "cmd": "旁白",
        "params": [],
        "text": "這是由清和源氏新田流的後裔姓『得川』而來，因為想強調其為源氏的後裔。"
      },
      {
        "cmd": "旁白",
        "params": [],
        "text": "新名字『家康』的『家』，也是取源氏的名將‧八幡太郎義家的一字過來的。"
      },
      {
        "cmd": "旁白",
        "params": [],
        "text": "只有清和源氏的後裔才能就征夷大將軍這個職……不知從何時開始有著這樣的傳聞。"
      },
      {
        "cmd": "旁白",
        "params": [],
        "text": "據說改松平元康為德川家康之後，在他的心中有了將來一定要得到將軍之位的想法。"
      },
      {
        "cmd": "改名",
        "params": [
          "德川家康,,"
        ],
        "text": "德川"
      },
      {
        "cmd": "自語",
        "params": [],
        "text": "今後我就取新田氏的後裔姓『德川』為名。"
      },
      {
        "cmd": "自語",
        "params": [],
        "text": "總有一天我一定……會成為征夷大將軍的！"
      },
      {
        "cmd": "離開設施",
        "params": []
      }

      {
        "cmd": "旁白",
        "params": [],
        "text": "某天──"
      },
      {
        "cmd": "旁白",
        "params": [],
        "text": "(立花道雪)在大樹下休息。"
      },
      {
        "cmd": "背景變更",
        "params": [
          "場地背景,黑暗,無效果"
        ]
      },
      {
        "cmd": "自語",
        "params": [],
        "text": "唔……我竟不知不覺睡著了。"
      },
      {
        "cmd": "自語",
        "params": [],
        "text": "下起陣雨了……真倒楣，"
      },
      {
        "cmd": "自語",
        "params": [],
        "text": "我得馬上回城鎮啊……"
      },
      {
        "cmd": "自語",
        "params": [],
        "text": "可是不想讓千鳥淋到雨，只好等雨停了。"
      },
      {
        "cmd": "旁白",
        "params": [],
        "text": "(立花道雪)將愛刀「千鳥」立在樹旁後，躺回大樹下，進入夢鄉。"
      },
      {
        "cmd": "旁白",
        "params": [],
        "text": "──這時，"
      },
      {
        "cmd": "ＳＥ開始",
        "params": [
          "忍者報告"
        ]
      },
      {
        "cmd": "停止時間",
        "params": [
          "0"
        ]
      },
      {
        "cmd": "自語",
        "params": [],
        "text": "閃光……！？"
      },
      {
        "cmd": "自語",
        "params": [],
        "text": "是妖物啊！喝，看我砍了你！"
      },
      {
        "cmd": "旁白",
        "params": [],
        "text": "雷擊中一旁的大樹，(立花道雪)也遭到雷擊。"
      },
      {
        "cmd": "旁白",
        "params": [],
        "text": "如果是一般人，這時早已沒命了。"
      },
      {
        "cmd": "旁白",
        "params": [],
        "text": "但(立花道雪)身經百戰的強健身軀，讓他輕鬆起身。"
      },
      {
        "cmd": "自語",
        "params": [],
        "text": "我剛砍中的……難道是雷神！"
      },
      {
        "cmd": "自語",
        "params": [],
        "text": "腿是有點麻，但渾身上下沒有傷……錯不了。"
      },
      {
        "cmd": "自語",
        "params": [],
        "text": "我的愛刀「千鳥」斬了雷神……哦哦！白光……閃映……"
      },
      {
        "cmd": "自語",
        "params": [],
        "text": "恍若妖刀……既然如此，今後就改名為「雷切」吧。"
      },
      {
        "cmd": "ＳＥ開始",
        "params": [
          "殴られる（メイン）"
        ]
      },
      {
        "cmd": "自語",
        "params": [],
        "text": "雨停了，我們回去吧，「雷切」。"
      },
      {
        "cmd": "ＳＥ停止",
        "params": [
          "雨"
        ]
      },
      {
        "cmd": "背景變更",
        "params": [
          "場面,據點內畫面,褪去"
        ]
      },
      {
        "cmd": "旁白",
        "params": [],
        "text": "日後，(立花道雪)的腿因為當時的雷擊不再靈活，出征時只能坐轎子。"
      },
      {
        "cmd": "旁白",
        "params": [],
        "text": "但他的鬥志仍和年輕時一樣。因為這則軼事和(立花道雪)的膽量，世人紛紛稱(立花道雪)為「雷神」。"
      },
      {
        "cmd": "未知68",
        "params": []
      }

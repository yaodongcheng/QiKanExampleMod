    "conditions": [
      {
        "type": "調查",
        "expression": "大名家::織田信長.存在"
      },
      {
        "type": "調查",
        "expression": "代入大名家Ａ:(大名家::織田信長)"
      },
      {
        "type": "調查",
        "operator": "==",
        "left": "人物::豐臣秀吉.所屬大名家",
        "right": "大名家::大名家Ａ"
      },
      {
        "type": "調查",
        "operator": "==",
        "left": "人物::主人公.身份",
        "right": "身份::浪人"
      },
      {
        "type": "調查",
        "operator": "==",
        "left": "事件::153",
        "right": "1"
      }
    ],
    "script": [
      {
        "cmd": "代入城Ｃ",
        "params": [
          "城::墨股"
        ]
      },
      {
        "cmd": "對話",
        "params": [
          "豐臣秀吉,主人公"
        ],
        "text": "哦哦，{二人稱名前}，你去那裡了呀？我找你找好久了。"
      },
      {
        "cmd": "對話",
        "params": [
          "豐臣秀吉,主人公"
        ],
        "text": "(織田信長.名)大人已經同意讓{二人稱}成為我的配下了！"
      },
      {
        "cmd": "對話",
        "params": [
          "豐臣秀吉,主人公"
        ],
        "text": "這樣我就可以依照約定，來迎接{二人稱}了。"
      },
      {
        "cmd": "對話",
        "params": [
          "主人公,豐臣秀吉"
        ],
        "text": "是！在下感激不盡！"
      },
      {
        "cmd": "對話",
        "params": [
          "豐臣秀吉,主人公"
        ],
        "text": "……{二人稱}的口氣變得那麼客氣感覺怪怪的呢……？"
      },
      {
        "cmd": "對話",
        "params": [
          "主人公,豐臣秀吉"
        ],
        "text": "不，這樣才是君臣之間該有的禮儀。如果{一人稱}像以前一樣用輕挑的口氣跟你講話的話，可是會被別人在背後說閒話的。"
      },
      {
        "cmd": "對話",
        "params": [
          "主人公,豐臣秀吉"
        ],
        "text": "主子會被人家說閒話，就代表做家臣的沒有盡到本分。所以就請你忍耐一下吧。"
      },
      {
        "cmd": "對話",
        "params": [
          "豐臣秀吉,主人公"
        ],
        "text": "嗯，{二人稱}的忠義讓我感到很欣慰。今後就拜託你囉，(主人公.名)！"
      },
      {
        "cmd": "對話",
        "params": [
          "主人公,豐臣秀吉"
        ],
        "text": "遵命！"
      },
      {
        "cmd": "對話",
        "params": [
          "豐臣秀吉,主人公"
        ],
        "text": "哦、我差點忘了。(織田信長.名)大人有命，他希望{二人稱}能夠換一個名字。"
      },
      {
        "cmd": "對話",
        "params": [
          "豐臣秀吉,主人公"
        ],
        "text": "用「(蜂須賀小六.名)」這來當一個武士的名字的話……感覺略嫌輕率了一點。"
      },
      {
        "cmd": "對話",
        "params": [
          "豐臣秀吉,主人公"
        ],
        "text": "為了避免{二人稱}被別人瞧不起，要想一個適合武士身份的新名字啊。"
      },
      {
        "cmd": "對話",
        "params": [
          "主人公,豐臣秀吉"
        ],
        "text": "感謝大人提醒。那麼，在下就捨棄以前的名字，從今以後便改稱「正勝」吧！"
      },
      {
        "cmd": "代入ａ",
        "params": [
          "人物::豐臣秀吉.武士功勳",
          "100"
        ]
      },
      {
        "cmd": "更新",
        "params": [
          "人物::豐臣秀吉.武士功勳",
          "ａ"
        ]
      },
      {
        "cmd": "人物登用",
        "params": [
          "蜂須賀小六,陪臣,豐臣秀吉"
        ]
      },
      {
        "cmd": "改名",
        "params": [
          "蜂須賀小六,,"
        ],
        "text": "蜂須賀"
      },
      {
        "cmd": "對話",
        "params": [
          "豐臣秀吉,主人公"
        ],
        "text": "(蜂須賀小六)嗎？嗯，真是個好名字！"
      },
      {
        "cmd": "離開設施",
        "params": []
      },
      {
        "cmd": "更新",
        "params": [
          "事件::157",
          "已發生"
        ]
      }
    ]
  },

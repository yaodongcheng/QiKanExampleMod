        ]
      },
      {
        "cmd": "旁白",
        "params": [],
        "text": "(松平広忠.姓)家乃三河豪族，面對周圍的有力大名向來畢恭畢敬，如履薄冰……"
      },
      {
        "cmd": "旁白",
        "params": [],
        "text": "前主松平清康則打破現狀，稱霸三河，後世譽為松平中興始祖。"
      },
      {
        "cmd": "旁白",
        "params": [],
        "text": "然而清康後來於軍中遭家臣阿部彌七郎暗殺，年僅二十五便告別人世，史稱『守山崩』……"
      },
      {
        "cmd": "旁白",
        "params": [],
        "text": "(松平広忠)繼位後，無以收服心生動搖的家臣，遂選擇(今川義元)作為後盾。"
      },
      {
        "cmd": "旁白",
        "params": [],
        "text": "其子竹千代則必須送至(今川義元.姓)家當人質作為證明。"
      },
      {
        "cmd": "旁白",
        "params": [],
        "text": "然而竹千代一行人坐船前往駿府的途中，因戶田康光等人之計而遭矇騙，結果航往反方向的尾張。"
      },
      {
        "cmd": "旁白",
        "params": [],
        "text": "俗話說屋漏偏逢連夜雨，劫掠主事者正是(今川義元.姓)家之敵(織田信秀)……"
      },
      {
        "cmd": "旁白",
        "params": [],
        "text": "(今川義元.姓)家對此失態勃然大怒，(松平広忠.姓)家愈加深陷苦境……"
      },
      {
        "cmd": "主人公別",
        "children": [
          {
            "cmd": "主人公分歧",
            "value": "松平広忠",
            "children": [
              {
                "cmd": "自語",
                "params": [],
                "text": "含淚割捨吾子竹千代，結果竟遭敵方劫掠……"
              },
              {
                "cmd": "自語",
                "params": [],
                "text": "還被(今川義元.姓)家疑有二心，我等接下來該如何走才好……"
              }
            ]
          },
          {
            "cmd": "主人公分歧",
            "value": "其他",
            "children": [
              {
                "cmd": "自語",
                "params": [],
                "text": "今後，(松平広忠.姓)家又會如何演變……"
              },
              {
                "cmd": "自語",
                "params": [],
                "text": "真希望主公能學習先代，多拿出一些魄力。"
              }
            ]
          }
        ]
      }
    ]

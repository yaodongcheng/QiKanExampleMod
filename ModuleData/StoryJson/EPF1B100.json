    "script": [
      {
        "cmd": "對話",
        "params": [
          "小姓,今川義元"
        ],
        "text": "(太原雪齋)大人，主公召喚您。"
      },
      {
        "cmd": "對話",
        "params": [
          "太原雪齋,今川義元"
        ],
        "text": "是嗎？馬上過去。"
      },
      {
        "cmd": "進入設施",
        "params": [
          "城主間"
        ]
      },
      {
        "cmd": "對話",
        "params": [
          "今川義元,太原雪齋"
        ],
        "text": "哦，你來啦，禪師。"
      },
      {
        "cmd": "對話",
        "params": [
          "太原雪齋,今川義元"
        ],
        "text": "請問有何貴幹？"
      },
      {
        "cmd": "對話",
        "params": [
          "今川義元,太原雪齋"
        ],
        "text": "是這樣的，我有個有趣的想法叫做「三國同盟」……"
      },
      {
        "cmd": "對話",
        "params": [
          "太原雪齋,今川義元"
        ],
        "text": "三國同盟？"
      },
      {
        "cmd": "對話",
        "params": [
          "今川義元,太原雪齋"
        ],
        "text": "我想你應該清楚，我正準備未來要進入京都。"
      },
      {
        "cmd": "對話",
        "params": [
          "今川義元,太原雪齋"
        ],
        "text": "但是我不能就這樣放駿河空城……這樣四周的大名便會想趁虛而入。"
      },
      {
        "cmd": "對話",
        "params": [
          "太原雪齋,今川義元"
        ],
        "text": "您說的沒錯。"
      },
      {
        "cmd": "對話",
        "params": [
          "今川義元,太原雪齋"
        ],
        "text": "因此……作為對未來的布局，我覺得鞏固與四周的關係才是首要之務。"
      },
      {
        "cmd": "對話",
        "params": [
          "太原雪齋,今川義元"
        ],
        "text": "就是……三國同盟嗎？"
      },
      {
        "cmd": "對話",
        "params": [
          "今川義元,太原雪齋"
        ],
        "text": "正是……也就是要同我們家領地接壤的(武田信玄.姓)家及(北條氏康.姓)家共三家締結同盟。"
      },
      {
        "cmd": "對話",
        "params": [
          "太原雪齋,今川義元"
        ],
        "text": "這確實是不錯的構想，不過能順利達成嗎？"
      },
      {
        "cmd": "對話",
        "params": [
          "今川義元,太原雪齋"
        ],
        "text": "沒錯……問題就在我不認為(武田信玄)家與(北條氏康)家會那麼乾脆地答應這件事。"
      },
      {
        "cmd": "對話",
        "params": [
          "今川義元,太原雪齋"
        ],
        "text": "因此希望禪師能助我一臂之力。"
      },
      {
        "cmd": "對話",
        "params": [
          "太原雪齋,今川義元"
        ],
        "text": "貧僧能幫上什麼忙？"
      },
      {
        "cmd": "對話",
        "params": [
          "今川義元,太原雪齋"
        ],
        "text": "禪師外交手腕靈活，希望你能說服(北條氏康)大人，讓他不要趁虛攻打駿河。"
      },
      {
        "cmd": "對話",
        "params": [
          "今川義元,太原雪齋"
        ],
        "text": "我就是不知道該怎麼對付(武田信玄)，至於(武田信玄.名)那邊，我的妻子正是(武田信玄.名)的姊姊，因此我可以來說服。"
      },
      {
        "cmd": "對話",
        "params": [
          "今川義元,太原雪齋"
        ],
        "text": "但是(北條氏康.名)那邊我真的束手無策，除了拜託禪師你別無他法了。"
      },
      {
        "cmd": "對話",
        "params": [
          "太原雪齋,今川義元"
        ],
        "text": "……我明白了，我會設法說服他。"
      },
      {
        "cmd": "對話",
        "params": [
          "今川義元,太原雪齋"
        ],
        "text": "好……我會派使者到(武田信玄.姓)處叫他過來駿河……也麻煩禪師把(北條氏康.名)帶去駿府。"
      },
      {
        "cmd": "對話",
        "params": [
          "太原雪齋,今川義元"
        ],
        "text": "貧僧遵命。在下馬上行動。"
      },
      {
        "cmd": "對話",
        "params": [
          "今川義元,太原雪齋"
        ],
        "text": "嗯，拜託了。"
      },
      {
        "cmd": "離開設施",
        "params": []
      },
      {
        "cmd": "對話",
        "params": [
          "太原雪齋,今川義元"
        ],
        "text": "真是的……被吩咐了麻煩的事情啊。算了，去說服看看吧。"
      },
      {
        "cmd": "外出",
        "params": []
      },

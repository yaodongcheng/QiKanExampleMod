    "script": [
      {
        "cmd": "對話",
        "params": [
          "門衛,主人公"
        ],
        "text": "什麼人！"
      },
      {
        "cmd": "對話",
        "params": [
          "主人公,門衛"
        ],
        "text": "貧僧為(今川義元.姓)家的使僧(太原雪齋)。前來請求拜訪(北條氏康)大人。"
      },
      {
        "cmd": "對話",
        "params": [
          "門衛,主人公"
        ],
        "text": "真是失禮了。來，請進。"
      },
      {
        "cmd": "進入設施",
        "params": [
          "城主間"
        ]
      },
      {
        "cmd": "ＢＧＭ變更",
        "params": [
          "大名主旋律"
        ]
      },
      {
        "type": "調查",
        "operator": "==",
        "left": "人物::北條氏康.認識標誌",
        "right": "1"
      },
      {
        "cmd": "分歧",
        "value": "1",
        "children": [
          {
            "cmd": "對話",
            "params": [
              "主人公,北條氏康"
            ],
            "text": "(北條氏康.姓)殿下，在下是(主人公.名)。"
          },
          {
            "cmd": "對話",
            "params": [
              "北條氏康,主人公"
            ],
            "text": "哦，是{二人稱名前}啊。今天前來有何貴幹？"
          }
        ]
      },
      {
        "cmd": "分歧",
        "value": "0",
        "children": [
          {
            "cmd": "對話",
            "params": [
              "主人公,北條氏康"
            ],
            "text": "初次見面，貧僧為(今川義元.姓)家的使僧(太原雪齋)。"
          },
          {
            "cmd": "對話",
            "params": [
              "北條氏康,主人公"
            ],
            "text": "久仰大名……話說，您今天前來有何貴幹？"
          }
        ]
      },
      {
        "cmd": "對話",
        "params": [
          "主人公,北條氏康"
        ],
        "text": "是……事實上，貧僧的主公(今川義元)託我向(北條氏康.姓)大人傳話……"
      },
      {
        "cmd": "對話",
        "params": [
          "北條氏康,主人公"
        ],
        "text": "哦……(今川義元.姓)大人嗎？什麼事？"
      },
      {
        "cmd": "對話",
        "params": [
          "主人公,北條氏康"
        ],
        "text": "事實上……"
      },
      {
        "cmd": "未知43",
        "params": [
          "2B 00 00 00"
        ]
      },
      {
        "cmd": "未知44",
        "params": [
          "2C 00 00 00"
        ]
      },
      {
        "cmd": "對話",
        "params": [
          "北條氏康,主人公"
        ],
        "text": "原來如此，三國同盟嗎？這件事如果真的締結成的話，確實會讓人心安不少。"
      },
      {
        "cmd": "對話",
        "params": [
          "主人公,北條氏康"
        ],
        "text": "既然這樣……"
      },
      {
        "cmd": "對話",
        "params": [
          "北條氏康,主人公"
        ],
        "text": "不，可是我對(武田信玄.名)……恕我失禮，我連對(今川義元.姓)大人也無法信賴。"
      },
      {
        "cmd": "對話",
        "params": [
          "主人公,北條氏康"
        ],
        "text": "………………"
      },
      {
        "cmd": "對話",
        "params": [
          "北條氏康,主人公"
        ],
        "text": "我想您應該知道……奠下北條根基的祖父早雲庵原本是今川家的武將，在奪取伊豆後，進入相模並自己宣布獨立。"
      },
      {
        "cmd": "對話",
        "params": [
          "北條氏康,主人公"
        ],
        "text": "因此不論是先祖父早雲或是家父氏綱，都不會忘記今川家對我們的恩義之情，甚至還派援軍協助今川家的前主公氏輝大人……"
      },
      {
        "cmd": "對話",
        "params": [
          "主人公,北條氏康"
        ],
        "text": "我清楚……"
      },
      {
        "cmd": "對話",
        "params": [
          "北條氏康,北條氏康"
        ],
        "text": "所以說，在氏輝大人的弟弟(今川義元.名)大人繼承當家之位後，突然和長年來互相敵對的武田家締結和平，甚至還娶了他女兒……"
      },
      {
        "cmd": "對話",
        "params": [
          "北條氏康,主人公"
        ],
        "text": "過程中，當家一句拒絕的話也沒有……說這行為是背信背義也不為過。"
      },
      {
        "cmd": "對話",
        "params": [
          "主人公,北條氏康"
        ],
        "text": "………………"
      },
      {
        "cmd": "對話",
        "params": [
          "北條氏康,主人公"
        ],
        "text": "從那以來，我們在駿東地區就一直有小規模衝突……現在比起(武田信玄.姓)，可以說我更恨(今川義元.姓)大人。"
      },
      {
        "cmd": "對話",
        "params": [
          "主人公,北條氏康"
        ],
        "text": "原來還有這段過去啊。不過吾主已經痛改前非……還望您既往不咎。"
      },
      {
        "cmd": "對話",
        "params": [
          "北條氏康,主人公"
        ],
        "text": "唔唔……"
      },
      {
        "cmd": "對話",
        "params": [
          "主人公,北條氏康"
        ],
        "text": "這個同盟應該會為(北條氏康.姓)大人帶來不可計數的好處……畢竟對(北條氏康.姓)大人來說，四周都是敵人。"
      },
      {
        "cmd": "對話",
        "params": [
          "主人公,北條氏康"
        ],
        "text": "如果(今川義元.姓)、(北條氏康.姓)、(武田信玄.姓)締結起堅強的同盟關係的話，周圍的大名也就不敢對抗他了。"
      },
      {
        "cmd": "對話",
        "params": [
          "主人公,北條氏康"
        ],
        "text": "若想稱霸關東稱，我認為這個同盟是必要的……"
      },
      {
        "cmd": "對話",
        "params": [
          "北條氏康,主人公"
        ],
        "text": "您說的很有道理……但是我真的希望看到能讓我信賴的證明。"
      },
      {
        "cmd": "對話",
        "params": [
          "主人公,北條氏康"
        ],
        "text": "您說的很對……針對您說的「證明」，貧僧已有腹案。"
      },
      {
        "cmd": "對話",
        "params": [
          "主人公,北條氏康"
        ],
        "text": "我的主公(今川義元)與(武田信玄)大人是否為足以信賴的人物，貧僧認為您直接與他們見面就清楚了。"
      },
      {
        "cmd": "對話",
        "params": [
          "北條氏康,主人公"
        ],
        "text": "您說直接見面？"
      },
      {
        "cmd": "對話",
        "params": [
          "主人公,北條氏康"
        ],
        "text": "(武田信玄.姓)大人，(今川義元.名)邀請您至駿河的善得寺一會，務必讓貧僧同行……"
      },
      {
        "cmd": "對話",
        "params": [
          "北條氏康,主人公"
        ],
        "text": "什麼……竟然已經在等我了？"
      },
      {
        "cmd": "對話",
        "params": [
          "主人公,北條氏康"
        ],
        "text": "正是。"
      },
      {
        "cmd": "對話",
        "params": [

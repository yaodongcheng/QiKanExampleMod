	  <!-- ========================================== -->
    <!-- 1. 按钮背景画刷：控制背景颜色变化 -->
    <!-- ========================================== -->
    <Brush Name="Simple.Button.Bg">
        <Layers>
            <!-- 使用 9宫格切片图 BlankWhiteSquare_9 作为底图，方便染色 -->
            <BrushLayer Name="Default" Sprite="BlankWhiteSquare_9" />
        </Layers>
        <Styles>
            <!-- 【默认状态】：半透明黑色背景 -->
            <Style Name="Default">
                <BrushLayer Name="Default" Color="#00000000" />
            </Style>
            
            <!-- 【悬浮状态】：变为亮灰色/半透明白色，提示玩家已选中 -->
            <Style Name="Hovered">
                <BrushLayer Name="Default" Color="#BFAD6FFF" /> 
            </Style>

            <!-- 【按下状态】：稍微变深 -->
            <Style Name="Pressed">
                <BrushLayer Name="Default" Color="#000000FF" />
            </Style>
        </Styles>
    </Brush>

    <!-- ========================================== -->
    <!-- 2. 按钮文字画刷：控制文字颜色变化 -->
    <!-- ========================================== -->
    <Brush Name="Simple.Button.Text" 
           Font="FiraSansExtraCondensed-Regular" 
           TextHorizontalAlignment="Center" 
           TextVerticalAlignment="Center">
        <Styles>
            <!-- 【默认状态】：普通的白色文字 -->
            <Style Name="Default" 
                   FontColor="#FFFFFFFF" 
                   FontSize="24" />
            
            <!-- 【悬浮状态】：文字变为金色/黄色 -->
            <Style Name="Hovered" 
                   FontColor="#000000FF" 
                   FontSize="24" />
                   
            <!-- 【按下状态】：文字变灰 -->
            <Style Name="Pressed" 
                   FontColor="#AAAAAAFF" 
                   FontSize="24" />
        </Styles>
    </Brush>
</Brushes>
